# Auth provider: firebase, azure_ad, jwt
AUTH_PROVIDER=firebase
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_SA_PATH=.secrets/firebase-service-account.json

# Azure AD (if using azure_ad provider)
# AZURE_TENANT_ID=your-tenant-id
# AZURE_CLIENT_ID=your-client-id

# Generic JWT (if using jwt provider)
# JWT_JWKS_URL=https://your-provider.com/.well-known/jwks.json
# JWT_ISSUER=https://your-provider.com/
# JWT_AUDIENCE=your-api-audience

# OAuth 2.1 (for Claude Desktop / remote MCP clients)
# JWT signing uses the Firebase SA private key (RS256) — no separate secret needed
OAUTH_ISSUER=http://localhost:8001
# OAUTH_ENABLED=true
# OAUTH_ACCESS_TOKEN_TTL=3600
# OAUTH_REFRESH_TOKEN_TTL=86400

# Firebase Web SDK (public client-side config for OAuth authorize page)
FIREBASE_WEB_API_KEY=your-firebase-web-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com

# GCP
GCP_PROJECT_ID=your-gcp-project-id

# LLM
LLM_MODEL=openai/qwen3.5:9b
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama

# Gemini (uncomment to use)
# LLM_MODEL=gemini/gemini-2.5-flash
# GEMINI_API_KEY=your-gemini-api-key
